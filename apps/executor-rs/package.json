{
  "name": "@judge/executor-rs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "cargo build --target-dir .cargo-artifacts --manifest-path Cargo.toml",
    "dev": "cargo run --target-dir .cargo-artifacts --manifest-path Cargo.toml",
    "lint": "cargo fmt --manifest-path Cargo.toml --check",
    "test": "cargo test --target-dir .cargo-artifacts --manifest-path Cargo.toml",
    "typecheck": "cargo check --target-dir .cargo-artifacts --manifest-path Cargo.toml"
  }
}
